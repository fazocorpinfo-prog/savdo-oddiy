# MongoDB Atlas — SERVER tomon (faqat Netlify Functions). VITE_ prefiksi YO'Q!
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=savdo

# Cloudflare R2 — SERVER tomon (presigned upload uchun). Hammasi maxfiy, brauzerga chiqmaydi.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=savdo-images
# Bucket'ning ommaviy manzili — custom domen (tavsiya) yoki pub-xxx.r2.dev
R2_PUBLIC_BASE_URL=
